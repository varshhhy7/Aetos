# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-server*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# reference repos (see spec section 5) - not used, cloned for reference only if ever needed
external/
# vendored editor source lives in src/opencut/; these are the reference clones
# (each has its own nested .git) and are not part of the app.
/OpenCut/
/vit/

# local tooling / editor state
/.claude/
/.tokensave/

# typescript
*.tsbuildinfo
next-env.d.ts

# oversized raw demo video (exceeds GitHub 100MB limit) and local MCP config
demoFolder/
.mcp.json
.vercel/auto-deploy.log
